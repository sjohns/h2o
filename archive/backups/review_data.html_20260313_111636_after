<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>H2O — Review Packing Data</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body data-role="review" class="bg-light">

    <header class="py-3 px-4 text-white mb-4"
            style="background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <span class="fw-bold fs-5">H2O Packing Data</span>
                <span class="ms-2 small" style="color:#94a3b8">Review current SKU data and preview proposed changes</span>
            </div>
            <button id="signOutBtn" class="btn btn-sm" type="button"
                    style="background:rgba(255,255,255,0.1);color:#cbd5e1;border:1.5px solid #475569">Sign Out</button>
        </div>
    </header>

    <main class="container-lg pb-5">

        <!-- Current Published Data -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center py-3">
                <h2 class="h5 mb-0">Current Published Data</h2>
                <div class="d-flex gap-2">
                    <button id="downloadBtn" class="btn btn-outline-secondary btn-sm" type="button">Download Excel</button>
                    <button id="downloadJsonBtn" class="btn btn-outline-secondary btn-sm" type="button">Download load_packing_data.js</button>
                </div>
            </div>
            <div id="currentDataContent" class="card-body">
                <p class="text-muted mb-0">Loading&hellip;</p>
            </div>
        </div>

        <!-- Results -->
        <div class="card mb-4 shadow-sm" id="resultsCard" hidden>
            <div class="card-header py-3">
                <h2 class="h5 mb-0" id="resultsTitle">Results</h2>
            </div>
            <div id="resultsContent" class="card-body"></div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="js/admin_data.js"></script>
</body>
</html>
