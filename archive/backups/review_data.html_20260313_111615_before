<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>H2O — Review Packing Data</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body data-role="review" class="bg-light">

    <header class="py-3 px-4 text-white mb-4"
            style="background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <span class="fw-bold fs-5">H2O Packing Data</span>
                <span class="ms-2 small" style="color:#94a3b8">Review current SKU data and preview proposed changes</span>
            </div>
            <button id="signOutBtn" class="btn btn-sm" type="button"
                    style="background:rgba(255,255,255,0.1);color:#cbd5e1;border:1.5px solid #475569">Sign Out</button>
        </div>
    </header>

    <main class="container-lg pb-5">

        <!-- Help -->
        <div class="accordion mb-4 shadow-sm" id="helpAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button fw-semibold" type="button"
                            data-bs-toggle="collapse" data-bs-target="#helpBody" aria-expanded="true">
                        How to use this page
                    </button>
                </h2>
                <div id="helpBody" class="accordion-collapse collapse show">
                    <div class="accordion-body">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <p class="fw-semibold small text-uppercase text-muted mb-2">Workflow</p>
                                <ol class="ps-3 small mb-0">
                                    <li class="mb-1"><strong>Download</strong> — Get the current data as an Excel workbook. Open it in Excel or Google Sheets.</li>
                                    <li class="mb-1"><strong>Edit</strong> — Add, remove or update SKUs. Use the dropdown in the Active column (Y/N). Do not add or remove columns.</li>
                                    <li class="mb-1"><strong>Upload</strong> — Select your modified file using the file picker below.</li>
                                    <li class="mb-1"><strong>Validate</strong> — Check the file for errors before previewing.</li>
                                    <li class="mb-1"><strong>Preview</strong> — See exactly what will change compared to the live data.</li>
                                    <li class="mb-0"><strong>Contact an admin</strong> — Share the validated file with an admin to publish the approved changes.</li>
                                </ol>
                            </div>
                            <div class="col-md-6">
                                <p class="fw-semibold small text-uppercase text-muted mb-2">Tips</p>
                                <ul class="ps-3 small mb-0">
                                    <li class="mb-1">The <strong>Active</strong> column only accepts <strong>Y</strong> or <strong>N</strong>. Use the dropdown in Excel.</li>
                                    <li class="mb-1"><strong>Display Order</strong>, <strong>Length</strong>, <strong>Popularity Score</strong>, and bundle sizes must be positive whole numbers.</li>
                                    <li class="mb-1">The <strong>Product Type</strong> column on the SKUs sheet must match a name on the Product Types sheet.</li>
                                    <li class="mb-1">You can validate and preview changes freely — nothing is published until an admin approves.</li>
                                    <li class="mb-0">If validation fails, the error list will show the exact row and field that needs fixing.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Current Published Data -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center py-3">
                <h2 class="h5 mb-0">Current Published Data</h2>
                <div class="d-flex gap-2">
                    <button id="downloadBtn" class="btn btn-outline-secondary btn-sm" type="button">Download Excel</button>
                    <button id="downloadJsonBtn" class="btn btn-outline-secondary btn-sm" type="button">Download load_packing_data.js</button>
                </div>
            </div>
            <div id="currentDataContent" class="card-body">
                <p class="text-muted mb-0">Loading&hellip;</p>
            </div>
        </div>

        <!-- Results -->
        <div class="card mb-4 shadow-sm" id="resultsCard" hidden>
            <div class="card-header py-3">
                <h2 class="h5 mb-0" id="resultsTitle">Results</h2>
            </div>
            <div id="resultsContent" class="card-body"></div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="js/admin_data.js"></script>
</body>
</html>
