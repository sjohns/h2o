# Copy this file to python_process/.env and adjust values for your environment.

# Root folder for versioned Parquet snapshots and current.json pointer.
H2O_DATA_ROOT=/home/stephen/Desktop/h2o/python_process/data/master

# Source JS file used by admin import bootstrap.
H2O_LOAD_JS_SOURCE=/home/stephen/Desktop/h2o/H2O/html/load_packing_data.js

# SQLite database path (authoritative store with FK/UNIQUE constraints).
H2O_SQLITE_DB_PATH=/home/stephen/Desktop/h2o/python_process/data/master/h2o_master.sqlite3

# ID used for admin endpoints (send as x-admin-id header).
H2O_ADMIN_ID=admin

# Password used for admin endpoints (send as x-admin-password header).
H2O_ADMIN_PASSWORD=change_me
